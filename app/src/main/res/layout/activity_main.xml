<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.main.MainActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/miniPlayer"
        style="@style/Widget.MyMusicPlayer.MiniPlayerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <SeekBar
                android:id="@+id/seekMiniPlayerProgress"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:max="100"
                android:minHeight="2dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="0"
                android:splitTrack="false"
                android:thumb="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:id="@+id/imageMiniPlayerCover"
                    android:layout_width="@dimen/size_mini_player_cover"
                    android:layout_height="@dimen/size_mini_player_cover"
                    android:background="@drawable/bg_player_cover"
                    android:padding="7dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img"
                    tools:ignore="ContentDescription" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textMiniPlayerTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/mini_player_idle"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                    <TextView
                        android:id="@+id/textMiniPlayerArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/no_artist"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/app_text_secondary" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonMiniPlayerAction"
                    style="@style/Widget.MyMusicPlayer.MiniPlayerAction"
                    android:layout_width="@dimen/size_mini_player_action"
                    android:layout_height="@dimen/size_mini_player_action"
                    android:contentDescription="@string/play"
                    app:icon="@drawable/ic_play_arrow"
                    app:iconSize="@dimen/icon_size_emphasis" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/miniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonTheme"
                        style="@style/Widget.MyMusicPlayer.SurfaceIconButton"
                        android:layout_width="@dimen/size_top_bar_icon_button"
                        android:layout_height="@dimen/size_top_bar_icon_button"
                        android:contentDescription="@string/action_switch_to_dark_theme"
                        app:icon="@drawable/ic_theme_dark"
                        app:iconSize="@dimen/icon_size_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSearch"
                        style="@style/Widget.MyMusicPlayer.SecondaryButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:text="@string/action_search"
                        app:icon="@drawable/ic_search_simple"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWave"
                    style="@style/Widget.MyMusicPlayer.SectionCard"
                    android:layout_width="match_parent"
                    android:layout_height="500dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/app_surface"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="28dp">

                        <TextView
                            android:id="@+id/textWaveTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wave_title"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="@color/app_text_primary" />

                        <TextView
                            android:id="@+id/textWaveSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="@string/wave_subtitle_loading"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                            android:textColor="@color/app_text_secondary"
                            tools:text="Start a random music flow" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonWaveAction"
                            style="@style/Widget.MyMusicPlayer.PlayerPrimaryButton"
                            android:layout_width="@dimen/size_wave_action_button"
                            android:layout_height="@dimen/size_wave_action_button"
                            android:layout_marginTop="20dp"
                            android:contentDescription="@string/play"
                            android:enabled="false"
                            app:icon="@drawable/ic_play_arrow"
                            app:iconSize="@dimen/icon_size_wave" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/layoutSections"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPlaylists"
                        style="@style/Widget.MyMusicPlayer.SectionCard"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/card_playlists"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="@color/app_text_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLocalMusic"
                        style="@style/Widget.MyMusicPlayer.SectionCard"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/card_local_music"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="@color/app_text_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardDownloaded"
                        style="@style/Widget.MyMusicPlayer.SectionCard"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/card_downloaded"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="@color/app_text_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <TextView
                    android:id="@+id/textRecentPlaceholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/section_recent"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/app_text_primary" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_track" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
