<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:id="@+id/layoutCollapsed"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textCollapsedTitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/buttonCollapsedPlayPause"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textPlaybackSource"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="My Wave" />

    <ImageView
        android:id="@+id/imageAlbumCover"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="28dp"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_player_cover"
        android:padding="36dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_player_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textPlaybackSource"
        tools:ignore="ContentDescription" />

    <LinearLayout
        android:id="@+id/layoutExpanded"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageAlbumCover">

        <TextView
            android:id="@+id/textExpandedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/mini_player_idle"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            tools:text="Track Title" />

        <TextView
            android:id="@+id/textExpandedArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/no_artist"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@android:color/darker_gray"
            tools:text="Artist Name" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonAddToPlaylist"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="@string/player_action_add_symbol"
                android:textSize="20sp" />

            <Button
                android:id="@+id/buttonFavorite"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:text="@string/player_action_favorite_off_symbol"
                android:textSize="20sp" />

            <Button
                android:id="@+id/buttonDownload"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:text="@string/player_action_download_symbol"
                android:textSize="20sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekBarProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:enabled="false"
            android:max="100"
            android:progress="0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/player_time_zero"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

            <TextView
                android:id="@+id/textTotalDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_time_zero"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonPrevious"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="@string/player_previous"
                android:textSize="16sp" />

            <Button
                android:id="@+id/buttonExpandedPlayPause"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:text="@string/play"
                android:textSize="18sp" />

            <Button
                android:id="@+id/buttonNext"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="@string/player_next"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
