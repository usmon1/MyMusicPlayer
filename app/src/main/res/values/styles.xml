<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.MyMusicPlayer.MiniPlayerCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/app_surface</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.MiniPlayerAction" parent="Widget.Material3.Button.IconButton.Filled">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">@color/app_accent_on</item>
        <item name="backgroundTint">@color/app_accent</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.PlayerActionButton" parent="Widget.Material3.Button.IconButton.Outlined">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">@color/app_accent_dark</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.PlayerTransportButton" parent="Widget.MyMusicPlayer.PlayerActionButton">
        <item name="backgroundTint">@color/app_surface_alt</item>
        <item name="iconTint">@color/app_text_primary</item>
    </style>

    <style name="Widget.MyMusicPlayer.PlayerPrimaryButton" parent="Widget.Material3.Button.IconButton.Filled">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">@color/app_accent_on</item>
        <item name="backgroundTint">@color/app_accent</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/app_accent</item>
        <item name="android:textColor">@color/app_accent_on</item>
        <item name="iconTint">@color/app_accent_on</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/app_outline</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="iconTint">@color/app_text_primary</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.CompactSecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/app_outline</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="iconTint">@color/app_text_primary</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.CompactIconButton" parent="Widget.Material3.Button.IconButton.Outlined">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="iconTint">@color/app_text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.CompactDestructiveIconButton" parent="Widget.MyMusicPlayer.CompactIconButton">
        <item name="strokeColor">@color/app_accent_soft</item>
        <item name="iconTint">@color/app_accent_dark</item>
    </style>

    <style name="Widget.MyMusicPlayer.DestructiveButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/app_accent_soft</item>
        <item name="android:textColor">@color/app_accent_dark</item>
        <item name="iconTint">@color/app_accent_dark</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.SurfaceIconButton" parent="Widget.Material3.Button.IconButton.Outlined">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="backgroundTint">@color/app_surface</item>
        <item name="iconTint">@color/app_text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.ListCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/app_surface</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.MyMusicPlayer.SectionCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/app_surface</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
